{
  "schemaVersion": 1,
  "id": "lumynlib",
  "version": "${mod_version}",
  "name": "LumynLib",
  "description": "Multi-tool library mod for mods by Lumynity Studios",
  "authors": [
    "Lumynity Studios"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/lumynlib",
    "sources": "https://github.com/Lumynity-Studios/LumynLib/",
    "issues": "https://github.com/Lumynity-Studios/LumynLib/issues"
  },
  "license": "All Rights Reserved",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.lumynity.lib.fabric.LibFabric"
    ]
  },
  "mixins": [
    "lumynlib.mixins.json",
    "lumynlib_fabric.mixins.json"
  ],
  "fabric-datagen": [
    "net.lumynity.lib.datagen.fabric.FabricDatagen"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "${minecraft_version}",
    "java": ">=17",
    "architectury": ">=${architectury_api_version}",
    "fabric-api": "*"
  }
}
